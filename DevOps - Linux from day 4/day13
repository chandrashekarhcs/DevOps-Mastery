write a script to check current disk utilization 
- if disk usage is more than 70% 
  script should send an email to devops team
  also clear the files under /tmp & /opt/*.logs 

#!/bin/bash 

DISK_UTILIZATION=$(df -kh . | awk -F " " '{print$5}' | tail -1 | sed 's/%/ /g')

if  [ $DISK_UTILIZATION  -ge 70 ]
then 
  echo "system disk usage has gone beyond 70% please take action"
  mail -s "Subject: High disk usage" devopsteam@xyz.com 
  rm -rf /tmp/*
else 
 echo "system disk usage is lesser than 70%, we are good"
fi 



